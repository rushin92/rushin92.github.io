  <body>
    <div id="divApplab" class="appModern running" tabindex="1" style="width: 320px; height: 450px; display: block;"><div class="screen" tabindex="1" data-theme="default" id="screen1" style="display: block; height: 450px; width: 320px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255);"><button id="button1" style="padding: 0px; margin: 0px; border-style: solid; height: 70px; width: 310px; background-color: rgb(0, 255, 41); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 20px;">Search engine</button><button id="button2" style="padding: 0px; margin: 0px; border-style: solid; height: 75px; width: 310px; background-color: rgb(25, 0, 255); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 100px;">Xmusic</button><button id="button3" style="padding: 0px; margin: 0px; border-style: solid; height: 75px; width: 310px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 180px;">Travel Pges</button><button id="button4" style="padding: 0px; margin: 0px; border-style: solid; height: 55px; width: 300px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 270px;">More</button></div><div class="screen" tabindex="1" data-theme="default" id="screen2" style="display: none; height: 450px; width: 320px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255);"><button id="button5" style="padding: 0px; margin: 0px; border-style: solid; height: 35px; width: 60px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 10px;">Back</button><button id="button6" style="padding: 0px; margin: 0px; border-style: solid; height: 70px; width: 310px; background-color: rgb(255, 0, 247); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 70px;">Ghosts</button><button id="button7" style="padding: 0px; margin: 0px; border-style: solid; height: 65px; width: 310px; background-color: rgb(255, 0, 247); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 155px;">Vampires</button><button id="button8" style="padding: 0px; margin: 0px; border-style: solid; height: 60px; width: 310px; background-color: rgb(255, 0, 247); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 235px;">Dinosuars</button><button id="button9" style="padding: 0px; margin: 0px; border-style: solid; height: 65px; width: 315px; background-color: rgb(255, 0, 247); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 5px; top: 315px;">Dragons</button></div></div>
  </body>
</html>
